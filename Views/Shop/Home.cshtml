@model IEnumerable<EcommerceMVC.Models.Product>

@{
    ViewData["Title"] = "Welcome";
}

<div class="hero">
    <h1>🛍️ Welcome to ShopMVC</h1>
    <p>Discover amazing products at unbeatable prices</p>
    <a asp-action="Index" class="btn-hero">Shop Now</a>
</div>

<div class="container mt-5">
    <h2 class="section-title">Featured Products</h2>
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-3">
                <div class="product-card">
                    @if (!string.IsNullOrEmpty(product.Thumbnail))
                    {
                        <img src="@product.Thumbnail" alt="@product.Name" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <div class="rating">⭐ @product.Rating.ToString("0.0")</div>
                        <div class="price-tag mt-2">@product.Price.ToString("C")</div>
                        <form asp-action="AddToCart" method="post" class="mt-3">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn-add-cart">Add to Cart</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <a asp-action="Index" class="btn-hero">View All Products</a>
    </div>
</div>